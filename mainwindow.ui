   <string notr="true">QMainWindow {
    background-color: #f0fafa;
}

QWidget {
    background-color: #f0fafa;
    font-family: Arial;
    font-size: 12px;
}

QPushButton {
    background-color: #4db6ac;
    color: #ffffff;
    border-radius: 8px;
    padding: 6px;
    font-weight: bold;
    border: 1px solid #3a9e94;
}

QPushButton:hover {
    background-color: #3a9e94;
}

QPushButton:disabled {
    background-color: #b2dfdb;
    color: #80cbc4;
}

QTextEdit {
    background-color: #ffffff;
    border: 2px solid #4db6ac;
	
    border-radius: 8px;
    padding: 5px;
    color: #00695c;
	font-size:14px;
}

QLabel {
    color: #00695c; 
    font-weight: bold;
	font:16px;
	qproperty-alignment: AlignCenter;
}

QLabel#slot0, QLabel#slot1, QLabel#slot2, QLabel#slot3, QLabel#slot4 {
    background-color: #b2dfdb;
    border: 2px solid #4db6ac;
    border-radius: 8px;
    color: #00695c;
    font-size: 14px;
    font-weight: bold;
    padding: 5px;
    min-height: 50px;
    qproperty-alignment: AlignCenter;
}

QLabel#semFullLabel, QLabel#semEmptyLabel {
    background-color: #e0f7f4;
    border: 2px solid #4db6ac;
    border-radius: 8px;
    padding: 8px;
    font-size: 13px;
}

QLabel#producerStatusLabel, QLabel#consumerStatusLabel {
    background-color: #e0f7f4;
    border: 2px solid #4db6ac;
    border-radius: 8px;
    padding: 8px;
    font-size: 13px;
}</string>
